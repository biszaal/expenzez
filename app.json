{
  "expo": {
    "name": "Expenzez",
    "slug": "expenzez",
    "version": "1.8.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "expenzez",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1226"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "description": "Smart expense tracking with AI insights and comprehensive financial management for users.",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/icon-ios.png",
      "buildNumber": "69",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "execute-api.eu-west-2.amazonaws.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "1.2",
              "NSExceptionRequiresForwardSecrecy": true
            },
            "cognito-idp.eu-west-2.amazonaws.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "1.2",
              "NSExceptionRequiresForwardSecrecy": true
            },
            "icons.duckduckgo.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "1.2",
              "NSExceptionRequiresForwardSecrecy": true,
              "NSIncludesSubdomains": true
            }
          }
        },
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "expenzez-redirect",
            "CFBundleURLSchemes": [
              "expenzez"
            ]
          }
        ],
        "NSCameraUsageDescription": "This app uses the camera to scan receipts for expense tracking.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to attach receipt images to expenses.",
        "NSFaceIDUsageDescription": "This app uses Face ID for secure authentication and app access.",
        "NSLocationWhenInUseUsageDescription": "This app uses location data to categorize expenses and find nearby merchants.",
        "NSUserTrackingUsageDescription": "Expenzez uses this to show you more relevant ads and to keep the core app free. You can change this anytime in your device settings."
      },
      "bundleIdentifier": "com.biszaal.expenzez"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundImage": "./assets/images/adaptive-background.png",
        "backgroundColor": "#3559CC"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.biszaaltech.expenzez",
      "versionCode": 38
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#0A1226"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4E7CFF",
          "defaultChannel": "default"
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "androidClientId": "904573665938-g7c644i3vp7m1rtj61ljvm0b5m98arq9.apps.googleusercontent.com",
          "iosClientId": "904573665938-iosplaceholder.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.904573665938-iosplaceholder"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-local-authentication",
      "expo-localization",
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "application/pdf"
          ],
          "iosActivationRules": "SUBQUERY(extensionItems, $extensionItem, SUBQUERY($extensionItem.attachments, $attachment, ANY $attachment.registeredTypeIdentifiers UTI-CONFORMS-TO \"com.adobe.pdf\").@count > 0).@count > 0",
          "iosShareExtensionName": "Expenzez Statement Import"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "blockedPermissions": [
              "android.permission.READ_MEDIA_IMAGES",
              "android.permission.READ_MEDIA_VIDEO",
              "android.permission.READ_EXTERNAL_STORAGE",
              "android.permission.WRITE_EXTERNAL_STORAGE"
            ]
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5406377320439537~8300036691",
          "iosAppId": "ca-app-pub-5406377320439537~9498935278"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Expenzez uses this to show you more relevant ads and to keep the core app free. You can change this anytime in your device settings."
        }
      ],
      "@sentry/react-native",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Balance",
              "label": "Expenzez Balance",
              "description": "Your total balance at a glance",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Budget",
              "label": "Expenzez Budget",
              "description": "This month's spend vs your budget",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Streak",
              "label": "Expenzez Streak",
              "description": "Your daily tracking streak",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "abdbfccb-cbc1-4be7-8fcc-76ac70f61747"
      }
    },
    "owner": "biszaaltech"
  }
}
